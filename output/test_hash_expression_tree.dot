digraph ExpressionTree {
  graph [rankdir=TB bgcolor="#FAFAFA" label="Árbol de Expresión Combinado"          fontsize=14 fontname="Helvetica"];
  node  [shape=circle fontname="Courier" fontsize=10];
  edge  [arrowsize=0.7];
  rule0 [label="Regla 1\nvowel+" shape=box style=filled fillcolor="#FFD700" fontname="Helvetica" fontsize=9];
  n0 [label="+" style=filled fillcolor="#DDA0DD" shape=circle fontname="Courier" fontsize=11];
  n1 [label="[21 chars]" style=filled fillcolor="#A8D8A8" shape=circle fontname="Courier" fontsize=11];
  n0 -> n1;
  rule0 -> n0 [style=dashed color=gray];
  rule1 [label="Regla 2\ndigit+" shape=box style=filled fillcolor="#FFD700" fontname="Helvetica" fontsize=9];
  n2 [label="+" style=filled fillcolor="#DDA0DD" shape=circle fontname="Courier" fontsize=11];
  n3 [label="[10 chars]" style=filled fillcolor="#A8D8A8" shape=circle fontname="Courier" fontsize=11];
  n2 -> n3;
  rule1 -> n2 [style=dashed color=gray];
  rule2 [label="Regla 3\n' '" shape=box style=filled fillcolor="#FFD700" fontname="Helvetica" fontsize=9];
  n4 [label="SP" style=filled fillcolor="#A8D8A8" shape=circle fontname="Courier" fontsize=11];
  rule2 -> n4 [style=dashed color=gray];
  rule3 [label="Regla 4\neof" shape=box style=filled fillcolor="#FFD700" fontname="Helvetica" fontsize=9];
  n5 [label="EOF" style=filled fillcolor="#A8D8A8" shape=circle fontname="Courier" fontsize=11];
  rule3 -> n5 [style=dashed color=gray];
}